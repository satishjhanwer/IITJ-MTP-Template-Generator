[flake8]
max-line-length = 88
# E203: whitespace before ':' — black formats slices this way
# W503: line break before binary operator — conflicts with black
extend-ignore = E203, W503
exclude =
    .venv,
    output,
    htmlcov,
    __pycache__,
    .git,
    .history
per-file-ignores =
    # Long compile-command strings in user-facing output are intentional
    scripts/generate.py:E501
    scripts/generate_simple.py:E501
